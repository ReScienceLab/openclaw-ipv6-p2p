{
  "id": "ipv6-p2p",
  "name": "IPv6 P2P",
  "description": "Direct encrypted P2P communication between OpenClaw instances via Yggdrasil IPv6",
  "version": "0.1.0",
  "channels": ["ipv6-p2p"],
  "skills": ["./skills/ipv6-p2p", "./skills/yggdrasil"],
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "peer_port": {
        "type": "integer",
        "default": 8099,
        "description": "Local port for the P2P peer server"
      },
      "data_dir": {
        "type": "string",
        "description": "Directory to store identity and peer data (default: ~/.openclaw/ipv6-p2p)"
      },
      "yggdrasil_peers": {
        "type": "array",
        "items": { "type": "string" },
        "description": "Additional Yggdrasil bootstrap peers"
      },
      "test_mode": {
        "type": "boolean",
        "default": false,
        "description": "Skip Yggdrasil IP validation (for local/Docker testing without Yggdrasil daemon)"
      }
    }
  },
  "uiHints": {
    "peer_port": { "label": "Peer Server Port", "placeholder": "8099" },
    "data_dir": { "label": "Data Directory" },
    "yggdrasil_peers": { "label": "Extra Yggdrasil Peers" },
    "test_mode": { "label": "Test Mode (no Yggdrasil)" }
  }
}
